# Spotfiy Integration must be added.
# OAUTH with Spotify


# 1. Hazırlık: Spotify Developer Kaydı
# Spotify verilerine erişmek için önce bir uygulama oluşturmanız gerekir:
#  * Spotify Developer Dashboard (https://developer.spotify.com/dashboard/)
#    adresine gidin.
# * "Create app" diyerek yeni bir uygulama oluşturun.
#   * Client ID ve Client Secret bilgilerini not edin.
#   * Redirect URI kısmına http://localhost:8080 gibi bir adres ekleyin (bu,
#     giriş yaptıktan sonra tarayıcının yönleneceği adrestir).

# 2. Gerekli Kütüphaneyi Kurma
# Python dünyasında Spotify için en popüler kütüphane Spotipy'dir:
#   1 pip install spotipy

# 3. Kimlik Doğrulama (Authentication)
# Kullanıcının çalma listelerine erişmek ve müziği kontrol etmek için
# "Authorization Code Flow" kullanmalısınız. spotipy bunu sizin için
# kolaylaştırır.

# 4. Projeye Entegrasyon Stratejisi
# main.py dosyanıza şu yapıyı ekleyebilirsiniz:

#  A. Kimlik Bilgilerini Yönetme
#  Güvenlik için client_id ve client_secret bilgilerini kodun içine yazmak
#  yerine bir .env dosyasında veya ortam değişkeni (environment variable)
#  olarak tutmanızı öneririm.

#  B. Spotify İstemcisini Hazırlama

#    1 import spotipy
#    2 from spotipy.oauth2 import SpotifyOAuth
#    3
#    4 # Gerekli izinler (scopes)
#    5 SCOPE = "user-library-read playlist-read-private
#    6       user-modify-playback-state"
#    7
#    8 sp = spotipy.Spotify(auth_manager=SpotifyOAuth(
#    9     client_id="SİZİN_CLIENT_ID",
#   10     client_secret="SİZİN_CLIENT_SECRET",
#   11     redirect_uri="http://localhost:8080",
#   12     scope=SCOPE
))

